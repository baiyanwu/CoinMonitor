<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="8dp"
    android:paddingEnd="16dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/notification_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/overlay_notification_title_color"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/notification_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/overlay_notification_body_color"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:ellipsize="end" />

    <LinearLayout
        android:id="@+id/notification_actions_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="start|center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/action_visibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/overlay_notification_action_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/action_drag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/overlay_notification_action_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/action_stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/overlay_notification_action_color"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
